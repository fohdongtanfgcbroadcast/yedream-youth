{
  "expo": {
    "name": "예닮드림 청년부",
    "slug": "yedream-youth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "yedream",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A90D9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yedream.youth"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A90D9",
        "foregroundImage": "./assets/logo.png"
      },
      "package": "com.yedream.youth",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro",
      "name": "예닮드림 청년부",
      "shortName": "예닮드림",
      "description": "예닮드림 청년부 재적관리 시스템",
      "lang": "ko",
      "themeColor": "#4A90D9",
      "backgroundColor": "#F8F9FA"
    },
    "experiments": {
      "baseUrl": "/yedream-youth"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ]
  }
}
